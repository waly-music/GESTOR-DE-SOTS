rules_version = '2';
// `sots`: fecha_programacion_sga, status_agenda, dilacion se actualizan solo vía import Excel
// (el cliente no los envía en saveGestion). No restringir aquí para no bloquear reimportaciones.
// Reglas reforzadas: lectura/escritura de `sots` acotada por contratista del perfil
// (users/{uid}). Los administradores conservan acceso global.
// Creación de `users/{uid}` solo con rol inicial "asesor" y campos permitidos.
// `metricas/{docId}`: admin lee global y agregados; asesor/supervisor solo su doc
// (`metricasDocId` en el perfil, mantenido por Cloud Function y cliente al cambiar contratista).

service cloud.firestore {
  match /databases/{database}/documents {

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userData() {
      return get(userPath()).data;
    }

    function signedIn() {
      return request.auth != null;
    }

    function hasUserDoc() {
      return signedIn() && exists(userPath());
    }

    // Comparación segura contratista null / string
    function normStr(v) {
      return v == null ? '' : v;
    }

    function roleIsAdmin(r) {
      return r == 'admin' || r == 'Admin' || r == 'ADMIN' ||
        r == 'administrator' || r == 'Administrator' ||
        r == 'administrador' || r == 'Administrador' ||
        r == 'superadmin' || r == 'SuperAdmin';
    }

    function roleIsSupervisor(r) {
      return r == 'supervisor' || r == 'Supervisor' || r == 'SUPERVISOR' ||
        r == 'supervisora' || r == 'Supervisora';
    }

    function roleIsAsesor(r) {
      return r == 'asesor' || r == 'Asesor' || r == 'ASESOR' ||
        r == 'asesora' || r == 'Asesora' || r == 'advisor' || r == 'Advisor';
    }

    // Siempre exigen sesión + documento de perfil antes de leer roles
    function isAdmin() {
      return signedIn() && hasUserDoc() && (
        roleIsAdmin(userData().rol) || roleIsAdmin(userData().role) || roleIsAdmin(userData().Role)
      );
    }

    function isSupervisor() {
      return signedIn() && hasUserDoc() && (
        roleIsSupervisor(userData().rol) || roleIsSupervisor(userData().role) || roleIsSupervisor(userData().Role)
      );
    }

    function isAsesor() {
      return signedIn() && hasUserDoc() && (
        roleIsAsesor(userData().rol) || roleIsAsesor(userData().role) || roleIsAsesor(userData().Role)
      );
    }

    function canReadOperational() {
      return isAdmin() || isSupervisor() || isAsesor();
    }

    function userOwnsContractorField(contractorField) {
      return normStr(contractorField) == normStr(userData().contratista);
    }

    // Perfil users.contratista == '__TODOS__' (solo admin lo asigna): ve todos los SOT.
    function contratistaEsTodos() {
      return normStr(userData().contratista) == '__TODOS__';
    }

    // Lectura de un documento sot: admin ve todo; __TODOS__ como admin; resto solo su contratista
    function canReadSotDoc() {
      return isAdmin()
        || (contratistaEsTodos() && (isSupervisor() || isAsesor()))
        || ((isSupervisor() || isAsesor()) && userOwnsContractorField(resource.data.contratista));
    }

    // No permitir mover órdenes a otro contratista salvo admin
    function contratistaUnchanged() {
      return request.resource.data.contratista == resource.data.contratista;
    }

    // Quitar gestión: admin/supervisor; asesor solo si perfil __TODOS__.
    function gestionClearAllowed() {
      return !(resource.data.tieneGestion == true
        && request.resource.data.tieneGestion == false)
        || isAdmin()
        || isSupervisor()
        || (contratistaEsTodos() && isAsesor());
    }

    function canUpdateSotDoc() {
      return gestionClearAllowed()
        && (
          isAdmin()
          || (contratistaEsTodos() && (isSupervisor() || isAsesor()) && contratistaUnchanged())
          || (
            isSupervisor()
            && userOwnsContractorField(resource.data.contratista)
            && contratistaUnchanged()
          )
          || (
            isAsesor()
            && userOwnsContractorField(resource.data.contratista)
            && contratistaUnchanged()
          )
        );
    }

    function canDeleteSotDoc() {
      return isAdmin()
        || (isSupervisor() && contratistaEsTodos())
        || (
          isSupervisor()
          && userOwnsContractorField(resource.data.contratista)
        );
    }

    function canCreateSotDoc() {
      return isAdmin()
        || (isSupervisor() && contratistaEsTodos())
        || (
          isSupervisor()
          && userOwnsContractorField(request.resource.data.contratista)
        );
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      // Autoregistro: solo rol asesor; sin privilege escalation (p. ej. admin)
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.rol == 'asesor'
        && request.resource.data.keys().hasOnly([
          'email', 'displayName', 'rol', 'contratista', 'createdAt', 'updatedAt', 'photoURL'
        ]);
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /config/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin() || isSupervisor();
    }

    match /metricas/{docId} {
      allow read: if signedIn() && hasUserDoc() && (
        isAdmin()
        || (contratistaEsTodos() && docId == 'global')
        || ((isSupervisor() || isAsesor()) && docId == userData().metricasDocId)
      );
      allow write: if false;
    }

    match /links/{id} {
      allow read: if signedIn() && hasUserDoc() && canReadOperational();
      allow create, update, delete: if isAdmin() || isSupervisor();
    }

    match /sots/{id} {
      allow read: if signedIn() && hasUserDoc() && canReadSotDoc();
      allow create: if signedIn() && hasUserDoc() && canCreateSotDoc();
      allow update: if signedIn() && hasUserDoc() && canUpdateSotDoc();
      allow delete: if signedIn() && hasUserDoc() && canDeleteSotDoc();
    }
  }
}
