rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userData() {
      return get(userPath()).data;
    }

    function signedIn() {
      return request.auth != null;
    }

    function hasUserDoc() {
      return exists(userPath());
    }

    /** Acepta admin / Admin / ADMIN (datos históricos en Firestore). */
    function isAdmin() {
      return signedIn() && hasUserDoc() && (
        userData().role == 'admin' ||
        userData().role == 'Admin' ||
        userData().role == 'ADMIN'
      );
    }

    function isSupervisor() {
      let r = userData().role;
      return r == 'supervisor' || r == 'Supervisor';
    }

    function isAsesor() {
      let r = userData().role;
      return r == 'asesor' || r == 'Asesor';
    }

    /** Usuario con perfil y rol operativo (lectura de todas las SOT). */
    function canReadAllSots() {
      return hasUserDoc() && (isAdmin() || isSupervisor() || isAsesor());
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /config/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /sots/{id} {
      allow read: if signedIn() && canReadAllSots();
      allow create: if isAdmin();
      allow update: if isAdmin() || isSupervisor() || isAsesor();
      allow delete: if false;
    }
  }
}
