# Copie este archivo a .env y complete con los datos del proyecto Firebase (Project settings).

# true = sin pantalla de login; rol/contratista en "Perfil local" (localStorage).
# Requiere reglas Firestore permisivas (firestore.rules actual). Ver README.
VITE_DISABLE_AUTH=true

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Región de Cloud Functions (debe coincidir con functions/index.js). Por defecto: us-central1
# VITE_FIREBASE_FUNCTIONS_REGION=us-central1
