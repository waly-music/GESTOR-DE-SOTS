# Copie este archivo a ".env" en la raíz del proyecto (no subir .env a git).
# Valores de ejemplo; reemplace por los de Firebase Console → Configuración del proyecto.
#
# GitHub Pages (Actions): Settings → Secrets and variables → Actions → "New repository secret"
# Cree un secreto por cada variable (mismo nombre: VITE_FIREBASE_API_KEY, etc.). Sin ellos el
# deploy en CI genera un build sin Firebase y la web queda en blanco con error en consola.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_FUNCTIONS_REGION=us-central1
