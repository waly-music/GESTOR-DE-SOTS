# Copie este archivo a .env y complete con los datos del proyecto Firebase (Project settings).

# Firebase Authentication (recomendado): omita esta línea o ponga false.
# true = modo demo sin login (use firestore.rules.no-auth en Firebase; ver README).
# VITE_DISABLE_AUTH=false

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Región de Cloud Functions (debe coincidir con functions/index.js). Por defecto: us-central1
# VITE_FIREBASE_FUNCTIONS_REGION=us-central1
